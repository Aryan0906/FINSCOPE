# =============================================================
# FINSCOPE INDIA — .env.template
# Sprint 1: Environment configuration template
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# =============================================================

# ═══════════════════════════════════════════════════════════════
# POSTGRESQL — Primary datastore
# ═══════════════════════════════════════════════════════════════
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finscope
POSTGRES_USER=finscope_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Read-only user for Streamlit frontend (SQL injection protection)
POSTGRES_READONLY_USER=finscope_reader
POSTGRES_READONLY_PASSWORD=CHANGE_ME_READONLY_PASSWORD

# ═══════════════════════════════════════════════════════════════
# AIRFLOW — Orchestration engine
# ═══════════════════════════════════════════════════════════════
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
AIRFLOW_ADMIN_EMAIL=admin@finscope.local

# IMPORTANT: Generate your own Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=GENERATE_YOUR_OWN_FERNET_KEY_SEE_COMMENT_ABOVE

# ═══════════════════════════════════════════════════════════════
# KAFKA — Message broker (Sprint 2: streaming)
# ═══════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Pre-created topics for NSE data streams
# (auto-created by Kafka if they don't exist)
KAFKA_TOPIC_PRICES=nse_prices_raw
KAFKA_TOPIC_NEWS=nse_news_raw
KAFKA_TOPIC_EARNINGS=nse_earnings_raw

# ═══════════════════════════════════════════════════════════════
# SPARK — Distributed processing (Sprint 3: batch)
# ═══════════════════════════════════════════════════════════════
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=4G
SPARK_WORKER_CORES=2

# ═══════════════════════════════════════════════════════════════
# CHROMADB — Vector store for RAG embeddings
# ═══════════════════════════════════════════════════════════════
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ═══════════════════════════════════════════════════════════════
# HUGGINGFACE — ML inference API (80 calls/day budget)
# ═══════════════════════════════════════════════════════════════
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_YOUR_TOKEN_HERE
HF_DAILY_CALL_LIMIT=80
HF_SUMMARISATION_MODEL=facebook/bart-large-cnn
HF_SENTIMENT_MODEL=ProsusAI/finbert

# ═══════════════════════════════════════════════════════════════
# NSE DATA — Stock symbols to track
# ═══════════════════════════════════════════════════════════════
# Comma-separated list of NSE symbols (no .NS suffix)
NSE_SYMBOLS=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK
ETL_LOOKBACK_DAYS=365

# ═══════════════════════════════════════════════════════════════
# NEWSAPI — News ingestion (optional, Phase 2)
# ═══════════════════════════════════════════════════════════════
# Get your API key at: https://newsapi.org/register
NEWS_API_KEY=YOUR_NEWSAPI_KEY_HERE
NEWS_PAGE_SIZE=100

# ═══════════════════════════════════════════════════════════════
# PATHS — Data directories
# ═══════════════════════════════════════════════════════════════
DELTA_LAKE_PATH=/opt/delta-lake
DATA_PATH=/opt/airflow/data
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# STREAMLIT — Frontend configuration (optional)
# ═══════════════════════════════════════════════════════════════
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
